# FacturaQR landing — control de caché
# El HTML/PHP no se cachea (para que los cambios se vean al instante).
# Los assets estáticos sí pueden cachearse.

# Dominio canónico: www → sin www (Google indexaba versiones duplicadas).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^www\.facturaqr\.app$ [NC]
  RewriteRule ^(.*)$ https://facturaqr.app/$1 [R=301,L]
</IfModule>

# El home es index.php (dinámico) para que SiteGround no lo cachee.
DirectoryIndex index.php index.html

# La página de agentes es .php por lo mismo; redirige la URL vieja.
Redirect 301 /agentes.html /agentes.php

<IfModule mod_headers.c>
  <FilesMatch "\.(html|php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    # SiteGround: no guardar en Dynamic Cache
    Header set X-Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
